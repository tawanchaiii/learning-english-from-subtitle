%% listening.tex.j2 — Listening Exercise PDF (TOEFL style, CS188 format) (legacy LaTeX)

<% include 'common.tex.j2' %>

\begin{document}

%% ===== COVER PAGE =====
\thispagestyle{empty}

\noindent
\begin{minipage}[t]{0.5\textwidth}
\textbf{\Large Listening Exercise}\\[0.3em]
\textbf{\large {{ movie_name }}}
\end{minipage}%
\hfill
\begin{minipage}[t]{0.4\textwidth}
\raggedleft
Movie CEFR: {{ detected_cefr }}\\
Your Level: {{ learner_cefr }}\\
Date: {{ generated_date }}
\end{minipage}

\vspace{1.5em}

\noindent Print Your Name: \rule{8cm}{0.4pt}

\vspace{2em}

\noindent There are 2 parts. ({{ total_points }} points total)

\vspace{1em}

\begin{center}
\begin{tabular}{|l|c|c|}
\hline
\textbf{Part} & \textbf{Questions} & \textbf{Points} \\
\hline
Part A: Short Conversations & {{ part_a_count }} & {{ part_a_points }} \\
\hline
Part B: Longer Talks & {{ part_b_count }} & {{ part_b_points }} \\
\hline
\textbf{Total} & \textbf{ {{ total_count }} } & \textbf{ {{ total_points }} } \\
\hline
\end{tabular}
\end{center}

\vspace{1.5em}

\noindent\textbf{Instructions:}
\begin{enumerate}[leftmargin=2em]
  \item Each question has an audio track. Play the track before answering.
  \item For multiple choice, select \textbf{one} answer by filling in the bubble completely.
  \item For short answer questions, write clearly inside the answer box.
  \item You may replay each track up to 2 times during the exercise.
\end{enumerate}

\vspace{1em}

\noindent\textit{Audio tracks are provided as separate files:
\texttt{<audio\_prefix>\_track\_NN.mp3}}
\\[0.3em]
\textit{Play each track before answering the questions for that passage.}

\vspace{0.5em}

\begin{itemize}[leftmargin=2em]
  \item[\bubble{A}] Unselected option (completely unfilled)
  \item[\filledbubble{C}] Your selected option (completely filled)
\end{itemize}

\vspace{1em}
\noindent\rule{\textwidth}{0.5pt}

\newpage

%% ===== PART A: SHORT CONVERSATIONS =====
\pdfbookmark[1]{Part A: Short Conversations ({{ part_a_points }} pts)}{partA}
\section*{Part A: Short Conversations ({{ part_a_points }} points)}

\noindent\textit{Listen to each conversation. Then answer the question that follows.}

\vspace{1em}

<% for passage in part_a_passages %>
%% --- Passage {{ passage.id }} ---
\noindent\textbf{Track {{ passage.track_number }}} \hfill \textit{ {{ passage.scene_ref | escape_latex }} }

\vspace{0.5em}

<% if passage.context %>
\noindent\textit{Context: {{ passage.context | escape_latex }} }

\vspace{0.3em}
<% endif %>

<% for q in passage.questions %>
\noindent\begin{minipage}{\textwidth}
\question{ {{ q.id }} }{ {{ q.points }} }{ {{ q.prompt | escape_latex }} }

\vspace{0.3em}
<% if q.type == "multiple_choice" %>
\begin{itemize}[leftmargin=2em, label={}]
<% for choice in q.choices %>
  \item[\bubble{ {{ choice.label }} }] {{ choice.text | escape_latex }}
<% endfor %>
\end{itemize}
<% elif q.type == "short_answer" %>
\writingbox{ {{ q.box_height | default("3cm") }} }
<% endif %>
\end{minipage}

\vspace{1em}
<% endfor %>

<% if not loop.last %>
\noindent\rule{\textwidth}{0.3pt}
\vspace{1em}
<% endif %>

<% endfor %>

